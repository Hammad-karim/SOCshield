# ===================================================================
# SOCshield — environment configuration
# -------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. The .env file is
# read by docker/entrypoint.sh at container startup. Never commit
# a populated .env to source control.
# ===================================================================

# ---- Flask dashboard ----
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=0
# Server engine: "flask" (dev) or "gunicorn" (production)
SOCSHIELD_SERVER=flask
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=60

# ---- Persistent storage (override only if you know what you're doing) ----
# The defaults match docker-compose.yml's volume layout.
# SOCSHIELD_DATA_DIR=/var/lib/socshield
# SOCSHIELD_LOGS_DIR=/var/lib/socshield/logs
# SOCSHIELD_REPORTS_DIR=/var/lib/socshield/reports
# SOCSHIELD_DB_PATH=/var/lib/socshield/alerts.db
# SOCSHIELD_TI_CACHE_PATH=/var/lib/socshield/threat_intel_cache.db

# ---- Tailed log sources ----
# Defaults point at the persistent volume; override to feed real
# host logs (see the commented bind mounts in docker-compose.yml).
# SOCSHIELD_AUTH_LOG=/var/lib/socshield/logs/auth.log
# SOCSHIELD_FIREWALL_LOG=/var/lib/socshield/logs/firewall.log
# SOCSHIELD_PRIV_LOG=/var/lib/socshield/logs/priv.log

# ---- Threat intelligence ----
# At least one of these enables real lookups. If both are empty,
# SOCSHIELD_MOCK_TI=1 is auto-enabled by the entrypoint.
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
# Set to 1 to force the mock providers (no outbound calls).
SOCSHIELD_MOCK_TI=

# ---- Operational flags ----
# Set to 1 on first run to seed sample log files into the persistent
# volume. Idempotent: only copies files that don't already exist.
SOCSHIELD_SEED_LOGS=

# Timezone for log timestamps.
TZ=UTC
