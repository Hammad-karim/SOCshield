# SOCshield — line-ending and diff rules
#
# Force LF for source / docs / config, CRLF only for Windows-native
# shell scripts so they run when checked out on Windows.
*               text=auto eol=lf

# Shell scripts that must stay CRLF on Windows
*.bat           text eol=crlf
*.cmd           text eol=crlf
PS1             text eol=crlf

# Explicitly mark these as text even when they have no extension
LICENSE         text eol=lf
Dockerfile      text eol=lf
.dockerignore   text eol=lf
.editorconfig   text eol=lf
.gitattributes  text eol=lf
